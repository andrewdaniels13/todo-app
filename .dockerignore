# Version control
.git
.gitignore
.gitattributes

# Environment files (NEVER bake secrets)
.env
.env.*
!.env.example

# Dependencies (reinstalled in container)
node_modules

# Build artifacts
dist
build
out

# Test artifacts
coverage
.nyc_output

# IDE and editor
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Documentation (not needed at runtime)
docs
*.md
!README.md

# Development files
tests
test
spec
*.test.*
*.spec.*

# Logs
*.log
logs

# Docker (prevent recursive copies)
Dockerfile*
docker-compose*
.docker

# Mault
.mault

# Claude
.claude
